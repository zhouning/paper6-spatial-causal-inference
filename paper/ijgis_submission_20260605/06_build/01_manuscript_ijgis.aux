\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Parallel trends illustration for the Difference-in-Differences scenario (Scenario~2). The treatment group (vehicle restriction zone) diverges sharply from the control group after policy implementation, with the DiD effect estimated at $-7.62$\,\textmu g/m$^3$.}}{18}{figure.caption.15}\protected@file@percent }
\newlabel{fig:did_trends}{{5}{18}{Parallel trends illustration for the Difference-in-Differences scenario (Scenario~2). The treatment group (vehicle restriction zone) diverges sharply from the control group after policy implementation, with the DiD effect estimated at $-7.62$\,\textmu g/m$^3$}{figure.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Estimated exposure-response function (ERF) for Scenario~4: factory distance vs.\ health score. The quadratic functional form ($R^2 = 0.94$) is recovered with 95\% confidence bands via IPSW kernel regression.}}{18}{figure.caption.16}\protected@file@percent }
\newlabel{fig:erf_curve}{{6}{18}{Estimated exposure-response function (ERF) for Scenario~4: factory distance vs.\ health score. The quadratic functional form ($R^2 = 0.94$) is recovered with 95\% confidence bands via IPSW kernel regression}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Spatial distribution of Conditional Average Treatment Effects (CATE) for the Chongqing building-LST case study. Positive values (red) indicate locations where high-rise buildings increase local temperature; negative values (blue) suggest thermal regulation. Effect heterogeneity is driven primarily by topographic position.}}{18}{figure.caption.16}\protected@file@percent }
\newlabel{fig:cate_map}{{7}{18}{Spatial distribution of Conditional Average Treatment Effects (CATE) for the Chongqing building-LST case study. Positive values (red) indicate locations where high-rise buildings increase local temperature; negative values (blue) suggest thermal regulation. Effect heterogeneity is driven primarily by topographic position}{figure.caption.16}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Complementarity of the three angles across six evaluation dimensions. Angle~A (Statistical) excels at causal identification and scalability; Angle~B (LLM) provides superior explainability and counterfactual reasoning; Angle~C (World Model) leads in spatial heterogeneity and temporal dynamics. No single angle dominates all dimensions, validating the multi-angle integration strategy.}}{19}{figure.caption.17}\protected@file@percent }
\newlabel{fig:cross_validation}{{8}{19}{Complementarity of the three angles across six evaluation dimensions. Angle~A (Statistical) excels at causal identification and scalability; Angle~B (LLM) provides superior explainability and counterfactual reasoning; Angle~C (World Model) leads in spatial heterogeneity and temporal dynamics. No single angle dominates all dimensions, validating the multi-angle integration strategy}{figure.caption.17}{}}
