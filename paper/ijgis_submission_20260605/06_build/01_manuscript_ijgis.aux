\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Pooled calibration of the SCCA residual-Moran downgrade rule across four spatial-process families (2{,}880 fits). Positive class: relative bias $>$ 25\%. Predictor: $|I_{\mathrm  {residual}}| \geq t$ AND permutation $p \leq 0.05$.}}{17}{table.caption.14}\protected@file@percent }
\newlabel{tab:moran_roc}{{7}{17}{Pooled calibration of the SCCA residual-Moran downgrade rule across four spatial-process families (2{,}880 fits). Positive class: relative bias $>$ 25\%. Predictor: $|I_{\mathrm {residual}}| \geq t$ AND permutation $p \leq 0.05$}{table.caption.14}{}}
\@writefile{lot}{\contentsline {table}{\numberline {8}{\ignorespaces Per-family behaviour of the residual-Moran rule. Mean residual Moran's $I$ is averaged over all cells of that family; TPR is at the manuscript default $t=0.10$. The rule is strong for kernel/non-stationary processes but weak for CAR, where the same relative bias leaves little simple-contiguity autocorrelation in the residual.}}{17}{table.caption.15}\protected@file@percent }
\newlabel{tab:moran_family}{{8}{17}{Per-family behaviour of the residual-Moran rule. Mean residual Moran's $I$ is averaged over all cells of that family; TPR is at the manuscript default $t=0.10$. The rule is strong for kernel/non-stationary processes but weak for CAR, where the same relative bias leaves little simple-contiguity autocorrelation in the residual}{table.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Threshold calibration for the SCCA residual-Moran downgrade rule. (a) Pooled ROC across candidate material thresholds. (b) Per-family ROC (process-dependent power): the 0.10 threshold, calibrated on a pooled design, exhibits strong external validity for kernel and non-stationary families (TPR $\approx $ 1.0) but limited power for CAR structures (TPR = 0.19), showing that the rule's discriminative ability depends on the unknown latent spatial process.}}{17}{figure.caption.16}\protected@file@percent }
\newlabel{fig:rocs}{{6}{17}{Threshold calibration for the SCCA residual-Moran downgrade rule. (a) Pooled ROC across candidate material thresholds. (b) Per-family ROC (process-dependent power): the 0.10 threshold, calibrated on a pooled design, exhibits strong external validity for kernel and non-stationary families (TPR $\approx $ 1.0) but limited power for CAR structures (TPR = 0.19), showing that the rule's discriminative ability depends on the unknown latent spatial process}{figure.caption.16}{}}
