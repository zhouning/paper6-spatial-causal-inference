\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Chongqing UHI covariate balance before and after caliper matching (Love plot) for the pre-treatment set. The 0.10 SMD threshold is shown for reference; the maximum post-match SMD is 0.104, a near-threshold miss rather than a strict balance pass.}}{12}{figure.caption.8}\protected@file@percent }
\newlabel{fig:loveplot}{{3}{12}{Chongqing UHI covariate balance before and after caliper matching (Love plot) for the pre-treatment set. The 0.10 SMD threshold is shown for reference; the maximum post-match SMD is 0.104, a near-threshold miss rather than a strict balance pass}{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Chongqing threshold-placebo dose-response. Vertical bars are matching-based 95\% CIs. The monotone increase from 8 to 12 floors is consistent with a dose-response interpretation; all estimates remain small relative to the thermal-retrieval and change-of-support uncertainties that accompany $\sim $1\,km LST extraction.}}{13}{figure.caption.9}\protected@file@percent }
\newlabel{fig:threshold}{{4}{13}{Chongqing threshold-placebo dose-response. Vertical bars are matching-based 95\% CIs. The monotone increase from 8 to 12 floors is consistent with a dose-response interpretation; all estimates remain small relative to the thermal-retrieval and change-of-support uncertainties that accompany $\sim $1\,km LST extraction}{figure.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4}{\ignorespaces Chongqing UHI adjustment variants. \emph  {pre\_treatment} is preferred because it avoids possible post-treatment Sentinel surfaces but slightly misses strict balance. Balance pass means maximum post-match SMD $<0.10$.}}{13}{table.caption.10}\protected@file@percent }
\newlabel{tab:chongqing}{{4}{13}{Chongqing UHI adjustment variants. \emph {pre\_treatment} is preferred because it avoids possible post-treatment Sentinel surfaces but slightly misses strict balance. Balance pass means maximum post-match SMD $<0.10$}{table.caption.10}{}}
